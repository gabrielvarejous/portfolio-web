---
type Variant = 'primary' | 'secondary' | 'ghost';

interface Props {
    href?: string;
    variant?: Variant;
    class?: string;
}

const {
    href, 
    variant = 'primary',
    class: className = ""
} = Astro.props as Props;

const base = 'inline-flex items-center justify-center rounded-xl px-6 py-3 text-sm font-medium transition-all duration-300'

const variants = {
    primary: 'bg-gradient-to-r from-cyan-500 to-violet-600 text-white hover:opacity-90',
    secondary: 'bg-white text-gray-800 hover:bg-gray-200',
    ghost: 'border border-white/20 text-white hover:bg-white/10',
}

const styles = `${base} ${variants[variant]} ${className}`
---

{ href ? (
    <a href={href} class={styles}>
        <slot />
    </a>
) : (
    <button class={styles}>
        <slot />
    </button>
)
}
